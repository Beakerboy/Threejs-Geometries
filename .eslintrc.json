{
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "env": {
    "browser": true,
    "es6": true
  },
  "extends": [
    "mdcs",
    "plugin:compat/recommended"
  ],
  "globals": {
    "Building": true,
    "BuildingPart": true,
    "BuildingShapeUtils": true,
    "MultiBuildingPart": true,
    "PyramidGeometry": true,
    "RampGeometry": true,
    "Shape": true,
    "THREE": true,
    "Vector2": true,
    "apis": true,
    "scene": true
  },
  "rules": {
    "no-throw-literal": [
      "error"
    ],
    "import/extensions": [
      "error",
      "always"
    ],
    "quotes": [
      "error",
      "single"
    ],
    "prefer-const": [
      "error",
      {
        "destructuring": "any",
        "ignoreReadBeforeAssign": false
      }
    ]
  }
}
